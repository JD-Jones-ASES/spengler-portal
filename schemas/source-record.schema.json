{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source-record.schema.json",
  "title": "Source records",
  "type": "object",
  "required": ["records"],
  "additionalProperties": false,
  "properties": {
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "title", "url", "accessed", "source_note", "citation_status"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "kind": {
            "enum": ["source-text", "primary-philosophical", "scholarly-secondary", "encyclopedia", "dictionary", "reference", "biographical", "license", "other"]
          },
          "title": { "type": "string", "minLength": 2 },
          "author": { "type": "string" },
          "publisher": { "type": "string" },
          "year": { "type": ["string", "integer"] },
          "url": { "type": "string", "pattern": "^https://" },
          "accessed": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "source_note": { "type": "string", "minLength": 10, "description": "Evidence the verifier actually saw on the page (title, author, dates visible)." },
          "license_note": { "type": "string" },
          "citation_status": { "enum": ["verified", "provisional", "needs-review"] }
        }
      }
    }
  }
}
