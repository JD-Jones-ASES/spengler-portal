{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "annotation.schema.json",
  "title": "Annotations",
  "type": "object",
  "required": ["unit_id", "annotations"],
  "additionalProperties": false,
  "properties": {
    "unit_id": { "type": "string" },
    "annotations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "selector", "anchor", "note", "evidence", "status", "provenance"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "kind": {
            "enum": ["lexicon-term", "historical-reference", "cross-culture-parallel", "translation-note", "form-observation", "scholarly-reception", "difficult-material", "concordance-link", "teacher-note"]
          },
          "selector": {
            "type": "object",
            "additionalProperties": false,
            "required": ["exact"],
            "properties": {
              "exact": { "type": "string", "minLength": 2 },
              "prefix": { "type": "string" },
              "suffix": { "type": "string" },
              "position": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "start": { "type": "integer" },
                  "end": { "type": "integer" },
                  "generated": { "type": "boolean" }
                }
              }
            }
          },
          "anchor": { "type": "string", "minLength": 2, "description": "Student-facing label, usually the excerpt." },
          "note": { "type": "string", "minLength": 20 },
          "cultures": { "type": "array", "items": { "enum": ["indian", "apollinian", "magian", "faustian", "egyptian", "chinese", "mexican"] } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "see_also": { "type": "array", "items": { "type": "string" } },
          "attribution": {
            "type": "object",
            "additionalProperties": false,
            "required": ["scholar", "citation", "stance"],
            "properties": {
              "scholar": { "type": "string", "minLength": 2 },
              "work": { "type": "string" },
              "year": { "type": ["string", "integer"] },
              "stance": { "enum": ["critical", "sympathetic", "corrective", "contextual"] },
              "citation": { "type": "string" }
            }
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["claim_type", "citations"],
              "properties": {
                "claim_type": {
                  "enum": ["source-text-observation", "interpretive", "lexical-definition", "historical-context", "cross-cultural-context", "translation-philology", "scholarly-interpretation", "publication-context", "difficult-material"]
                },
                "citations": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "status": {
            "type": "object",
            "additionalProperties": false,
            "required": ["content_status", "citation_status"],
            "properties": {
              "content_status": { "enum": ["student-ready", "draft", "needs-review"] },
              "citation_status": { "enum": ["verified", "provisional", "needs-review"] },
              "surfaces": { "type": "array", "items": { "enum": ["reader", "lexicon", "search", "trail"] } }
            }
          },
          "provenance": {
            "type": "object",
            "additionalProperties": false,
            "required": ["author", "created", "method"],
            "properties": {
              "author": { "type": "string" },
              "created": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
              "method": { "enum": ["hand-authored", "source-checked-draft", "reviewed"] },
              "reviewer": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
